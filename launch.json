{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "AutoWebPwn",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["-u", "http://testphp.vulnweb.com", "-o", "report.pdf"],
            "console": "integratedTerminal"
        },
        {
            "name": "DVWA (Low Security)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["-u", "http://localhost/dvwa", "--cookie", "security=low; PHPSESSID=xxx", "-o", "report_dvwa.pdf"],
            "console": "integratedTerminal"
        },
        {
            "name": "WebGoat",
